export TERM="screen-256color"

# Hardcoded ANSI escape sequences for performance
bold=$'\e[1m'
reset=$'\e[0m'

black=$'\e[30m'
red=$'\e[31m'
green=$'\e[32m'
yellow=$'\e[33m'
blue=$'\e[34m'
purple=$'\e[35m'
cyan=$'\e[36m'
white=$'\e[37m'

# Approximate extended colors
orange=$'\e[38;5;166m'
violet=$'\e[38;5;61m'
gray=$'\e[38;5;244m'
