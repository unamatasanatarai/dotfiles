# -----------------------------------------------------------------------------
# Apps
# -----------------------------------------------------------------------------

lctrl + lcmd - t      : open -na /Applications/Alacritty.app
ralt - return        : open -na /Applications/Alacritty.app


# -----------------------------------------------------------------------------
# Workspaces (Spaces)
# -----------------------------------------------------------------------------

lalt - q             : yabai -m space --focus 1
lalt - w             : yabai -m space --focus 2
lalt - e             : yabai -m space --focus 3
lalt - r             : yabai -m space --focus 4

lalt + lshift - q     : yabai -m window --space 1; yabai -m space --focus 1
lalt + lshift - w     : yabai -m window --space 2; yabai -m space --focus 2
lalt + lshift - e     : yabai -m window --space 3; yabai -m space --focus 3
lalt + lshift - r     : yabai -m window --space 4; yabai -m space --focus 4

lalt - tab           : yabai -m space --focus recent


# -----------------------------------------------------------------------------
# Focus
# -----------------------------------------------------------------------------

lalt - h             : yabai -m window --focus west
lalt - j             : yabai -m window --focus south
lalt - k             : yabai -m window --focus north
lalt - l             : yabai -m window --focus east


# -----------------------------------------------------------------------------
# Move Windows
# -----------------------------------------------------------------------------

lalt + lshift - h     : yabai -m window --warp west
lalt + lshift - j     : yabai -m window --warp south
lalt + lshift - k     : yabai -m window --warp north
lalt + lshift - l     : yabai -m window --warp east


# -----------------------------------------------------------------------------
# Layouts
# -----------------------------------------------------------------------------

# Toggle float / tile
lalt + lshift - space : yabai -m window --toggle float

# Fullscreen (native macOS fullscreen)
lcmd + lshift - f     : yabai -m window --toggle zoom-fullscreen

# Balance sizes
lcmd + lshift - e     : yabai -m space --balance

# Flatten tree equivalent
lcmd + lshift - x     : yabai -m space --mirror y-axis


# -----------------------------------------------------------------------------
# Resize
# -----------------------------------------------------------------------------

lcmd + lshift - h     : yabai -m window --resize left:-50:0; \
                      yabai -m window --resize right:-50:0

lcmd + lshift - j     : yabai -m window --resize bottom:0:50; \
                      yabai -m window --resize top:0:50

lcmd + lshift - k     : yabai -m window --resize bottom:0:-50; \
                      yabai -m window --resize top:0:-50

lcmd + lshift - l     : yabai -m window --resize left:50:0; \
                      yabai -m window --resize right:50:0
