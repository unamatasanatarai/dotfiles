# -----------------------------------------------------------------------------
# Apps
# -----------------------------------------------------------------------------

ctrl + cmd - t      : open -na /Applications/Alacritty.app
alt - return        : open -na /Applications/Alacritty.app


# -----------------------------------------------------------------------------
# Workspaces (Spaces)
# -----------------------------------------------------------------------------

alt - q             : yabai -m space --focus 1
alt - w             : yabai -m space --focus 2
alt - e             : yabai -m space --focus 3
alt - r             : yabai -m space --focus 4

alt + shift - q     : yabai -m window --space 1; yabai -m space --focus 1
alt + shift - w     : yabai -m window --space 2; yabai -m space --focus 2
alt + shift - e     : yabai -m window --space 3; yabai -m space --focus 3
alt + shift - r     : yabai -m window --space 4; yabai -m space --focus 4

alt - tab           : yabai -m space --focus recent


# -----------------------------------------------------------------------------
# Focus
# -----------------------------------------------------------------------------

alt - h             : yabai -m window --focus west
alt - j             : yabai -m window --focus south
alt - k             : yabai -m window --focus north
alt - l             : yabai -m window --focus east


# -----------------------------------------------------------------------------
# Move Windows
# -----------------------------------------------------------------------------

alt + shift - h     : yabai -m window --warp west
alt + shift - j     : yabai -m window --warp south
alt + shift - k     : yabai -m window --warp north
alt + shift - l     : yabai -m window --warp east


# -----------------------------------------------------------------------------
# Layouts
# -----------------------------------------------------------------------------

# Toggle float / tile
alt + shift - space : yabai -m window --toggle float

# Fullscreen (native macOS fullscreen)
cmd + shift - f     : yabai -m window --toggle zoom-fullscreen

# Balance sizes
cmd + shift - e     : yabai -m space --balance

# Flatten tree equivalent
cmd + shift - x     : yabai -m space --mirror y-axis


# -----------------------------------------------------------------------------
# Resize
# -----------------------------------------------------------------------------

cmd + shift - h     : yabai -m window --resize left:-50:0; \
                      yabai -m window --resize right:-50:0

cmd + shift - j     : yabai -m window --resize bottom:0:50; \
                      yabai -m window --resize top:0:50

cmd + shift - k     : yabai -m window --resize bottom:0:-50; \
                      yabai -m window --resize top:0:-50

cmd + shift - l     : yabai -m window --resize left:50:0; \
                      yabai -m window --resize right:50:0
