# -----------------------------------------------------------------------------
# Apps
# -----------------------------------------------------------------------------

lctrl + lcmd - t      : open -na /Applications/Alacritty.app
ralt - return        : open -na /Applications/Alacritty.app


# -----------------------------------------------------------------------------
# Workspaces
# -----------------------------------------------------------------------------

lalt - q             : aerospace workspace 1 > /dev/null 2>&1
lalt - w             : aerospace workspace 2 > /dev/null 2>&1
lalt - e             : aerospace workspace 3 > /dev/null 2>&1
lalt - r             : aerospace workspace 4 > /dev/null 2>&1

lalt + lshift - q     : aerospace move-node-to-workspace 1 --focus-follows-window > /dev/null 2>&1
lalt + lshift - w     : aerospace move-node-to-workspace 2 --focus-follows-window > /dev/null 2>&1
lalt + lshift - e     : aerospace move-node-to-workspace 3 --focus-follows-window > /dev/null 2>&1
lalt + lshift - r     : aerospace move-node-to-workspace 4 --focus-follows-window > /dev/null 2>&1

lalt - tab           : aerospace workspace-back-and-forth


# -----------------------------------------------------------------------------
# Focus
# -----------------------------------------------------------------------------

lalt - h             : aerospace focus left
lalt - j             : aerospace focus down
lalt - k             : aerospace focus up
lalt - l             : aerospace focus right


# -----------------------------------------------------------------------------
# Move Windows
# -----------------------------------------------------------------------------

lalt + lshift - h     : aerospace move left
lalt + lshift - j     : aerospace move down
lalt + lshift - k     : aerospace move up
lalt + lshift - l     : aerospace move right


# -----------------------------------------------------------------------------
# Layouts
# -----------------------------------------------------------------------------

lalt + lshift - space : aerospace layout floating tiling

# Fullscreen
lcmd + lshift - f     : aerospace fullscreen

# Balance sizes
lcmd + lshift - e     : aerospace balance-sizes

# Flatten workspace tree
lcmd + lshift - n     : aerospace flatten-workspace-tree


# -----------------------------------------------------------------------------
# Resize
# -----------------------------------------------------------------------------

lcmd + lshift - h     : aerospace resize width -50
lcmd + lshift - j     : aerospace resize height +50
lcmd + lshift - k     : aerospace resize height -50
lcmd + lshift - l     : aerospace resize width +50
