# -----------------------------------------------------------------------------
# Apps
# -----------------------------------------------------------------------------

ctrl + cmd - t      : open -na /Applications/Alacritty.app
alt - return        : open -na /Applications/Alacritty.app


# -----------------------------------------------------------------------------
# Workspaces
# -----------------------------------------------------------------------------

alt - q             : aerospace workspace 1 > /dev/null 2>&1
alt - w             : aerospace workspace 2 > /dev/null 2>&1
alt - e             : aerospace workspace 3 > /dev/null 2>&1
alt - r             : aerospace workspace 4 > /dev/null 2>&1

alt + shift - q     : aerospace move-node-to-workspace 1 --focus-follows-window > /dev/null 2>&1
alt + shift - w     : aerospace move-node-to-workspace 2 --focus-follows-window > /dev/null 2>&1
alt + shift - e     : aerospace move-node-to-workspace 3 --focus-follows-window > /dev/null 2>&1
alt + shift - r     : aerospace move-node-to-workspace 4 --focus-follows-window > /dev/null 2>&1

alt - tab           : aerospace workspace-back-and-forth


# -----------------------------------------------------------------------------
# Focus
# -----------------------------------------------------------------------------

alt - h             : aerospace focus left
alt - j             : aerospace focus down
alt - k             : aerospace focus up
alt - l             : aerospace focus right


# -----------------------------------------------------------------------------
# Move Windows
# -----------------------------------------------------------------------------

alt + shift - h     : aerospace move left
alt + shift - j     : aerospace move down
alt + shift - k     : aerospace move up
alt + shift - l     : aerospace move right


# -----------------------------------------------------------------------------
# Layouts
# -----------------------------------------------------------------------------

alt + shift - space : aerospace layout floating tiling

# Fullscreen
cmd + shift - f     : aerospace fullscreen

# Balance sizes
cmd + shift - e     : aerospace balance-sizes

# Flatten workspace tree
cmd + shift - n     : aerospace flatten-workspace-tree


# -----------------------------------------------------------------------------
# Resize
# -----------------------------------------------------------------------------

cmd + shift - h     : aerospace resize width -50
cmd + shift - j     : aerospace resize height +50
cmd + shift - k     : aerospace resize height -50
cmd + shift - l     : aerospace resize width +50
