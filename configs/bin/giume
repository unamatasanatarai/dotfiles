#!/usr/bin/env bash

if git config user.name >/dev/null 2>&1 && git config user.email >/dev/null 2>&1; then
    printf "Git identity already configured. Skipping.\n"
    exit 0
fi

__conf="${XDG_CONFIG_HOME:-$HOME/.config}/gi/giume.config"

if [[ -f "$__conf" ]]; then
    # shellcheck disable=SC1090
    source "$__conf"

    if [[ -n "${GIU_NAME:-}" && -n "${GIU_EMAIL:-}" ]]; then
        printf "Using defaults from %s\n" "$__conf"
        giu "$GIU_NAME" "$GIU_EMAIL"
        exit $?
    fi
fi

printf 'No global git identity found and no GIU defaults configured.

To set up, run:
  mkdir -p "%s"
  printf '\''GIU_NAME="Your Name"\nGIU_EMAIL="you@example.com"\n'\'' > "%s"
  ${EDITOR:-vi} "%s"

Alternatively set git globals directly:
  git config --global user.name "Your Name"
  git config --global user.email "you@example.com"\n' \
    "${__conf%/*}" "$__conf" "$__conf" >&2

exit 1
