#!/usr/bin/env bash

if [[ $# -lt 1 ]]; then
    printf "Usage: %s <command>\n" "${0##*/}" >&2
    exit 1
fi

EDIT_BIN="${EDITOR:-vim}"

if ! command -v "$EDIT_BIN" >/dev/null 2>&1; then
    printf "Error: Editor '%s' not found or not executable.\n" "$EDIT_BIN" >&2
    exit 1
fi

TMP_PATH="/tmp/.cmd_path_$$"

if ! command -v "$1" >"$TMP_PATH" 2>/dev/null; then
    printf "Error: Command '%s' not found in PATH.\n" "$1" >&2
    rm -f "$TMP_PATH"
    exit 1
fi

read -r CMD_PATH <"$TMP_PATH"
rm -f "$TMP_PATH"

if [[ -z "$CMD_PATH" ]]; then
    printf "Error: Failed to resolve path for '%s'.\n" "$1" >&2
    exit 1
fi

exec "$EDIT_BIN" "$CMD_PATH"
