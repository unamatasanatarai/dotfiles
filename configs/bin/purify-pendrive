#!/usr/bin/env bash

dir="${1:-.}"
[[ "$dir" != "/" ]] && dir="${dir%/}"

if [[ ! -e "$dir" ]]; then
    printf 'error: path does not exist: %s\n' "$dir" >&2
    exit 1
fi

if [[ ! -d "$dir" ]]; then
    printf 'error: not a directory: %s\n' "$dir" >&2
    exit 2
fi

printf "wait...\n"

find "$dir" -depth \( \
    -name '._*' -o \
    -name '.DS_Store' -o \
    -name 'Thumbs.db' -o \
    -name 'desktop.ini' -o \
    -name '.fseventsd' -o \
    -name '.Spotlight-V100' -o \
    -name '.Trashes' -o \
    -name '.apdisk' -o \
    -name '$RECYCLE.BIN' -o \
    -name 'System Volume Information' -o \
    -name '.Trash-1000' -o \
    -name 'LOST.DIR' \
    \) -exec rm -rfv -- {} +

status=$?

if [[ $status -ne 0 ]]; then
    printf 'error: cleanup failed\n' >&2
    exit 3
fi

printf 'done\n'
exit 0
