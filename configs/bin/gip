#!/usr/bin/env bash

# Get current branch
current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

if [ -z "$current_branch" ]; then
  echo "Error: Not inside a Git repository."
  exit 1
fi

# Ensure remote 'origin' exists
if ! git remote get-url origin >/dev/null 2>&1; then
  echo "Error: Remote 'origin' is not configured."
  exit 1
fi

# Fetch latest refs
git fetch origin >/dev/null 2>&1

# Check if remote branch exists
if git show-ref --verify --quiet "refs/remotes/origin/$current_branch"; then
  ahead_count=$(git rev-list --count HEAD ^origin/"$current_branch")
else
  echo "Remote branch origin/$current_branch does not exist yet."
  ahead_count=$(git rev-list --count HEAD)
fi

# Decide whether to push
if [ "$ahead_count" -eq 0 ]; then
  echo "Nothing to push. Your branch is up to date with origin/$current_branch."
  exit 0
else
  echo "You have $ahead_count commit(s) ahead (or branch not yet pushed)."
fi

# Push branch
git push -u origin "$current_branch"
