#!/usr/bin/env bash

REMOTE="$1"
if [[ -z "$REMOTE" || ! "$REMOTE" =~ ^git@ ]]; then
    printf "Usage: %s git@github.com:user/repo.git\n" "${0##*/}"
    exit 1
fi

[[ -f README.md ]] || printf "# Readme\n" > README.md
if [[ ! -f .gitignore ]]; then
    printf "# macOS\n.DS_Store\n\n# Node\nnode_modules/\n\n# Python\n__pycache__/\n*.log\n" > .gitignore
fi

git init
git branch -M master # Ensure primary branch is master
git remote add origin "$REMOTE"
giume

git add README.md .gitignore
git commit -m "Let's get goin'!"

printf "✅ Repo initialized on 'master' and connected to %s\n" "$REMOTE"
