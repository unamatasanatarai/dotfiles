#!/usr/bin/env bash

if [[ -n "$VIRTUAL_ENV" ]]; then
    printf "Error: You are already in a virtual environment: %s\n" "$VIRTUAL_ENV" >&2
    exit 1
fi

VENV_DIR="$PWD/venv"

if [[ -d "$VENV_DIR" ]]; then
    printf "Error: Virtual environment already exists at %s\n" "$VENV_DIR" >&2
    printf "Run: source venv/bin/activate\n"
    exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
    printf "Error: python3 not found in PATH.\n" >&2
    exit 1
fi

python3 -m venv "$VENV_DIR" || {
    printf "Error: Failed to create venv.\n" >&2
    exit 1
}

source "$VENV_DIR/bin/activate" || {
    printf "Error: Failed to activate venv.\n" >&2
    exit 1
}

python3 -m pip install --upgrade pip || {
    printf "Error: Pip upgrade failed.\n" >&2
    exit 1
}
python3 -m pip install uv || {
    printf "Error: uv installation failed.\n" >&2
    exit 1
}

deactivate

printf "✅ Virtual environment created and initialized with uv at: %s\n" "$VENV_DIR"
