#!/usr/bin/env bash

# Simple, robust 'watch' clone in Bash with no external dependencies.
# Features:
#  - Clean, non-flickering full-screen updates
#  - Minimal CPU usage (no 'date' fork in the loop)
#  - Resilient to tput errors (falls back to ANSI escape codes)
#  - Proper signal handling (INT, TERM, EXIT)
#  - Safe argument parsing

interval=2

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
	printf "Usage: %s [-i interval] <command> [args...]\n" "${0##*/}"
	exit 0
fi

while [[ $# -gt 0 ]]; do
	case "$1" in
	-i)
		interval="$2"
		shift 2
		;;
	--)
		shift
		break
		;;
	-*)
		printf "Error: invalid option: %s\n" "$1" >&2
		exit 1
		;;
	*)
		break
		;;
	esac
done

if [[ $# -eq 0 ]]; then
	printf "Usage: %s [-i interval] <command> [args...]\n" "${0##*/}" >&2
	exit 1
fi

if [[ ! "$interval" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
	printf "Error: interval must be a positive number: %s\n" "$interval" >&2
	exit 1
fi

if ! command -v "$1" >/dev/null 2>&1; then
	printf "Error: command not found: %s\n" "$1" >&2
	exit 1
fi

cmd=("$@")

# Query terminal sequences once to avoid spawning tput in the loop
term_smcup=$(tput smcup 2>/dev/null)
term_rmcup=$(tput rmcup 2>/dev/null)
term_civis=$(tput civis 2>/dev/null)
term_cnorm=$(tput cnorm 2>/dev/null)
term_clear=$(tput clear 2>/dev/null)
term_cup00=$(tput cup 0 0 2>/dev/null)

# Fallback to standard ANSI sequences if tput fails/is not supported
term_smcup=${term_smcup:-$'\e[?1049h'}
term_rmcup=${term_rmcup:-$'\e[?1049l'}
term_civis=${term_civis:-$'\e[?25l'}
term_cnorm=${term_cnorm:-$'\e[?25h'}
term_clear=${term_clear:-$'\e[H\e[2J'}
term_cup00=${term_cup00:-$'\e[H'}

# Clean up terminal state on exit or termination
trap 'printf "%s" "$term_cnorm$term_rmcup"; exit 0' INT TERM EXIT

# Switch to alternate screen and hide cursor
printf "%s" "$term_smcup$term_civis"

while true; do
	printf "%s" "$term_clear$term_cup00"
	# Pure Bash time formatting (Bash 4.2+), avoiding fork of date command
	printf '%(%H:%M:%S)T\n' -1
	printf "%s\n" "--------"
	"${cmd[@]}" 2>&1
	sleep "$interval"
done
