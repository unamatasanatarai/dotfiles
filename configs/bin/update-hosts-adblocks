#!/usr/bin/env bash

HOSTS_URL="https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts"
HOSTS_FILE="/etc/hosts"
MARK_BEGIN="# adblocking begin #"
MARK_END="# adblocking end #"

if [[ $EUID -ne 0 ]]; then
    printf "Error: This script must be run with sudo.\n" >&2
    exit 1
fi

printf "This will modify your /etc/hosts file. Are you sure? [No/yes] "
read -r answer
if [[ "${answer,,}" != "yes" ]]; then
    printf "Aborted\n"
    exit 0
fi

TMP_DOWNLOAD="/tmp/hosts_dl_$$"
TMP_NEW_HOSTS="/tmp/hosts_new_$$"
TMP_OLD_HOSTS="/tmp/hosts_old_$$"

printf "Downloading hosts from %s...\n" "$HOSTS_URL"
curl -so "$TMP_DOWNLOAD" "$HOSTS_URL"
if [[ $? -ne 0 ]]; then
    printf "Error: Failed to download hosts file.\n" >&2
    exit 1
fi

BACKUP_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/hosts-adblocks"
[[ -d "$BACKUP_DIR" ]] || mkdir -p "$BACKUP_DIR"

TIMESTAMP=$(date +"%Y-%m-%d-%H-%M-%S")
BACKUP_FILE="$BACKUP_DIR/hosts-$TIMESTAMP-$RANDOM"
cp "$HOSTS_FILE" "$BACKUP_FILE" && printf "Backup created: %s\n" "$BACKUP_FILE"

IN_BLOCK=0
while IFS= read -r line; do
    if [[ "$line" == "$MARK_BEGIN" ]]; then
        IN_BLOCK=1
        continue
    elif [[ "$line" == "$MARK_END" ]]; then
        IN_BLOCK=0
        continue
    fi

    if [[ $IN_BLOCK -eq 0 ]]; then
        printf "%s\n" "$line" >> "$TMP_OLD_HOSTS"
    fi
done < "$HOSTS_FILE"

cat "$TMP_OLD_HOSTS" > "$TMP_NEW_HOSTS" 
printf "\n%s\n" "$MARK_BEGIN" >> "$TMP_NEW_HOSTS"
cat "$TMP_DOWNLOAD" >> "$TMP_NEW_HOSTS"
printf "\n%s\n" "$MARK_END" >> "$TMP_NEW_HOSTS"

cp "$TMP_NEW_HOSTS" "$HOSTS_FILE"
if [[ $? -eq 0 ]]; then
    printf "✅ /etc/hosts updated successfully.\n"
else
    printf "❌ Error: Failed to write to %s\n" "$HOSTS_FILE" >&2
    exit 1
fi

rm -f "$TMP_DOWNLOAD" "$TMP_NEW_HOSTS" "$TMP_OLD_HOSTS"
sudo -k
